@using System.Text.Json
@using CodeMechanic.Razorhat
@using ImportMap = CodeMechanic.Razorhat.ImportMap
<!DOCTYPE html>
<html data-theme="dracula" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="hydro-config"/>
    <script defer src="~/hydro/hydro.js" asp-append-version="true"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <title>@ViewData["Title"] - thecodemechanic</title>

    <script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/focus@3.x.x/dist/cdn.min.js"></script>

    <script>
        window.AppConfig = @Html.Raw(JsonSerializer.Serialize(new
                           {
                               pocketbaseUrl = Environment.GetEnvironmentVariable("POCKETBASE_URL")
                           }));
    </script>

    @inject ImportMap ImportMap

    @Html.Raw(ImportMap.RenderAsScripts(debug: true))

    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>

    <link href="css/output.css" rel="stylesheet" type="text/css"/>
    <link href="css/temp_fixes.css" rel="stylesheet" type="text/css"/>

</head>

<body class="anonymous-pro-regular">

<header>
    <cm-navbar>foobar navbar</cm-navbar>
</header>

<div class="min-h-screen">
    <main role="main" class="h-full pb-3">
        @RenderBody()
    </main>
</div>

@* <span id="modal-placeholder"></span> *@

<partial name="_Footer"/>

@await RenderSectionAsync("Scripts", required: false)

@* *@
@* @{ *@
@*     bool force_alpine_to_see_sidebar = false; *@
@* } *@
