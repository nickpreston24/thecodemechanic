@* { *@
@*     Console.WriteLine("LOADING SIDEBAR BEFORE SITEJS"); *@
<drip-sidebar></drip-sidebar>

<script type="module" src="~/js/site.js" asp-append-version="true"></script>
@* } *@

@* *@
@* <script type="module"> *@
@*     console.log("[DEBUG] loading content sidebar (cache-busted)!") *@
@* *@
@*     // cache-bust so prod never serves a stale ContentSidebar.html *@
@*     const modalHtml = await fetch(`/components/ContentSidebar.html?v=${Date.now()}`) *@
@*         .then(r => r.text()); *@
@* *@
@*     const modalPlaceholder = document.getElementById("modal-placeholder"); *@
@*     modalPlaceholder.innerHTML = modalHtml; *@
@* *@
@*     if (window.Alpine) { *@
@*         window.Alpine.initTree(modalPlaceholder); *@
@*     } *@
@* </script> *@

</body>
</html>


