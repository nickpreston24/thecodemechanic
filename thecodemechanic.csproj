        <Watch Include="wwwroot/js/stores/*.js"/>
        <Watch Include="wwwroot/css/site.css"/>
        <Watch Include="wwwroot/img/*"/>
        <Watch Include="importmap.json"/>

        <!-- Watch Environment files -->
        <Watch Include=".env"/>

    </ItemGroup>

