<Project Sdk="Microsoft.NET.Sdk.Web">


    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>

        <ToolCommandName>cm</ToolCommandName>
        <PackageOutputPath>./nupkg</PackageOutputPath>
        <IsPackable>True</IsPackable>
        <PackAsTool>True</PackAsTool>

    </PropertyGroup>

    <!-- Drip.UI.SourceGen.csproj (or your main RazorHAT consuming .csproj) -->
    <PropertyGroup>
        <!-- This forces Roslyn to emit the real .g.cs files to a predictable folder -->
        <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
        <CompilerGeneratedFilesOutputPath>obj/Generated</CompilerGeneratedFilesOutputPath>

        <!-- Optional but nice: keep it clean on every build -->
        <CleanGeneratedFiles>true</CleanGeneratedFiles>
    </PropertyGroup>


    <ItemGroup>
        <!-- Watch C# logic files -->
        <Watch Include="**/*.cshtml.cs"/>
